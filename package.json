{
  "name": "nexus-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "A backend web application server for Project Nexus built using Express running on Node.js",
  "main": "src/server.ts",
  "scripts": {
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node --env-file=.env --conditions=production dist/src/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SGRiichi-TechDev/nexus-backend.git"
  },
  "author": "Toby Teo",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/SGRiichi-TechDev/nexus-backend/issues"
  },
  "homepage": "https://github.com/SGRiichi-TechDev/nexus-backend#readme",
  "dependencies": {
    "drizzle-orm": "^1.0.0-rc.4",
    "express": "^5.2.1",
    "postgres": "^3.4.9",
    "tsx": "^4.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^1.0.0-rc.4",
    "supabase": "^2.109.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "imports": {
    "#db/*": {
      "production": "./dist/src/db/*",
      "default": "./src/db/*"
    },
    "#controller/*": {
      "production": "./dist/src/controller/*",
      "default": "./src/controller/*"
    },
    "#routes/*": {
      "production": "./dist/src/routes/*",
      "default": "./src/routes/*"
    },
    "#drizzle/*": {
      "production": "./dist/drizzle/*",
      "default": "./drizzle/*"
    }
  }
}
